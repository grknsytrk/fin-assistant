# Opsiyonel runtime ayarlari
# Bu dosya dogrudan zorunlu degildir, lokal calisma icin referans amaclidir.
# Kullanmak icin kopyalayin: `.env.example` -> `.env`

# Ornek: alternatif config yolu
RAGFIN_CONFIG=config.yaml

# Optional LLM Commentary (OpenRouter)
OPENROUTER_API_KEY=
RAGFIN_LLM_ASSISTANT_ENABLED=false
RAGFIN_LLM_ASSISTANT_PROVIDER=openrouter
RAGFIN_LLM_ASSISTANT_MODEL=arcee-ai/trinity-large-preview:free
# Bos birakirsan max_tokens gonderilmez (limitsiz davranis)
RAGFIN_LLM_ASSISTANT_MAX_TOKENS=
RAGFIN_LLM_ASSISTANT_TIMEOUT_S=8
RAGFIN_LLM_ASSISTANT_TEMPERATURE=0.2
RAGFIN_LLM_ASSISTANT_REASONING_ENABLED=true
